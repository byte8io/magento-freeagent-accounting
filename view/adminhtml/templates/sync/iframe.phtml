declare(strict_types=1);

$embedUrl = $block->getEmbedUrl();
?>
<?php if ($embedUrl === ''): ?>
    <div class="message message-warning"><?= /* @noEscape */ __('Connect to FreeAgent before opening FreeAgent Sync.') ?></div>
<?php else: ?>
    <iframe src="<?= $escaper->escapeUrl($embedUrl) ?>"
            style="width:100%;min-height:calc(100vh - 220px);border:0;"
            title="<?= $escaper->escapeHtmlAttr(__('Byte8 FreeAgent Sync')) ?>"
            referrerpolicy="no-referrer"
            loading="eager">
    </iframe>
<?php endif; ?>
